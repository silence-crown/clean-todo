<?xml version="1.0" encoding="utf-8"?>
<!-- fab_outline.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Black background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/black" />
            <corners android:radius="16dp" /> <!-- Adjust the corner radius as needed -->
            <size
                android:width="56dp"
                android:height="56dp" /> <!-- Adjust the size as needed -->
        </shape>
    </item>
    <!-- White outline -->
    <item android:top="1.8dp" android:right="1.8dp" android:bottom="1.8dp" android:left="1.8dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1.8dp"
                android:color="@color/white" /> <!-- Adjust the width and color as needed -->
            <corners android:radius="16dp" /> <!-- Adjust the corner radius as needed -->
        </shape>
    </item>
</layer-list>
